{
  "name": "mitchellblonde/slack-error-detection",
  "description": "PHP/Laravel package to send application errors to Slack via Incoming Webhooks.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "SlackErrorNotifier\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SlackErrorNotifier\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "SlackErrorNotifier\\Laravel\\SlackErrorNotifierServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
